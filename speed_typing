import time

sentences = [
    "Python is a powerful programming language.",
    "Practice makes perfect in coding.",
    "Typing speed improves with regular practice.",
    "Artificial intelligence is changing the world."
]

import random
sentence = random.choice(sentences)

print("\n=== Typing Speed Tester ===\n")
print("Type the following sentence exactly:\n")
print(sentence)

input("\nPress Enter when you're ready...")

start_time = time.time()

typed_text = input("\nStart typing:\n")

end_time = time.time()

# Calculate time taken
time_taken = end_time - start_time

# Calculate WPM
word_count = len(typed_text.split())
wpm = (word_count / time_taken) * 60

# Calculate accuracy
correct_chars = 0
for i in range(min(len(sentence), len(typed_text))):
    if sentence[i] == typed_text[i]:
        correct_chars += 1

accuracy = (correct_chars / len(sentence)) * 100

print("\n===== Results =====")
print(f"Time Taken: {time_taken:.2f} seconds")
print(f"Words Per Minute (WPM): {wpm:.2f}")
print(f"Accuracy: {accuracy:.2f}%")